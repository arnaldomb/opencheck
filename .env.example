NODE_ENV=production
APP_URL=https://opencheck.ggtronic.com.br
API_URL=https://api.opencheck.ggtronic.com.br

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=troque-em-producao
DATABASE_URL=postgresql://postgres:troque-em-producao@localhost:5432/opencheck

# Redis
REDIS_PASSWORD=troque-em-producao
REDIS_URL=redis://:troque-em-producao@redis:6379

# Auth
JWT_SECRET=min-64-chars-here-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=min-64-chars-here-yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Criptografia AES-256-GCM (exatamente 32 chars)
ENCRYPTION_KEY=exactly-32-chars-for-aes256key!

# ── ASAAS ────────────────────────────────────────────────────────────────────
# Atenção: no .env de produção, escape o $ com $$ (ex: ASAAS_API_KEY=$$aact_...)
ASAAS_API_KEY=$$aact_prod_XXXXXXXX
ASAAS_SANDBOX=false
ASAAS_WEBHOOK_TOKEN=whsec_XXXXXXXX

# ── CTRL+SAFE ────────────────────────────────────────────────────────────────
CTRLSAFE_API_URL=https://api.ctrlsafe.com.br/api/functions/v1

# ── EZVIZ ────────────────────────────────────────────────────────────────────
EZVIZ_APP_KEY=
EZVIZ_APP_SECRET=
EZVIZ_REGION=br
EZVIZ_AUTH_URL=https://open.ezvizlife.com
EZVIZ_API_URL=https://isaopen.ezvizlife.com

# ── EVOLUTION API (WhatsApp) ──────────────────────────────────────────────────
EVOLUTION_API_URL=https://seu-evolution.exemplo.com
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=

# ── E-MAIL ───────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG.xxxxxxxxxxxxxxx
EMAIL_FROM=noreply@opencheck.com.br

# ── SUPERADMIN INICIAL (seed) ─────────────────────────────────────────────────
SUPERADMIN_EMAIL=admin@opencheck.com.br
SUPERADMIN_SENHA=troque-imediatamente-em-producao

# ── MINIO (Storage S3) ───────────────────────────────────────────────────────
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_URL=https://storage.opencheck.ggtronic.com.br
MINIO_ACCESS_KEY=minio-admin
MINIO_SECRET_KEY=troque-em-producao
MINIO_BUCKET=snapshots

# ── PRODUÇÃO (Traefik) ────────────────────────────────────────────────────────
DOMAIN=opencheck.ggtronic.com.br
ACME_EMAIL=admin@opencheck.com.br
