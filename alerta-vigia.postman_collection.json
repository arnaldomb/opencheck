{
  "info": {
    "name": "Alerta Vigia API",
    "description": "Coleção completa da API do Alerta Vigia. Configure a variável `baseUrl` (padrão http://localhost:3001) e execute primeiro o login para popular `token` automaticamente.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "alerta-vigia-collection-v2"
  },
  "variable": [
    { "key": "baseUrl",        "value": "http://localhost:3001",                         "type": "string" },
    { "key": "token",          "value": "",                                               "type": "string", "description": "JWT do tenant (preenchido pelo script de login)" },
    { "key": "superToken",     "value": "",                                               "type": "string", "description": "JWT do superadmin (preenchido pelo script de login)" },
    { "key": "pontoId",        "value": "",                                               "type": "string", "description": "Preenchido ao listar pontos" },
    { "key": "vigilanteId",    "value": "",                                               "type": "string", "description": "Preenchido ao listar vigilantes" },
    { "key": "agendaId",       "value": "",                                               "type": "string" },
    { "key": "cameraId",       "value": "",                                               "type": "string" },
    { "key": "clienteId",      "value": "",                                               "type": "string" },
    { "key": "planoId",        "value": "",                                               "type": "string" },
    { "key": "agentKeyPonto",  "value": "av_test_ponto1portariaprincipal000000000",       "type": "string", "description": "agentKey do ponto (obtido em Config completa)" },
    { "key": "eventoId",       "value": "",                                               "type": "string", "description": "Preenchido ao listar eventos" }
  ],
  "item": [

    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Login — Tenant",
          "event": [{ "listen": "test", "script": { "exec": [
            "var json = pm.response.json();",
            "if (json.token) { pm.collectionVariables.set('token', json.token); }",
            "pm.test('Login OK', () => pm.response.to.have.status(200));"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@segurancatotal.com.br\",\n  \"senha\": \"Admin@2024!\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth","login"] }
          }
        },
        {
          "name": "Login — Superadmin",
          "event": [{ "listen": "test", "script": { "exec": [
            "var json = pm.response.json();",
            "if (json.token) { pm.collectionVariables.set('superToken', json.token); }",
            "pm.test('Login OK', () => pm.response.to.have.status(200));"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@alertavigia.com.br\",\n  \"senha\": \"Admin@2024!\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth","login"] }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refresh\": \"<refresh_token>\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth","refresh"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth","logout"] }
          }
        }
      ]
    },

    {
      "name": "📍 Pontos",
      "item": [
        {
          "name": "Listar pontos",
          "event": [{ "listen": "test", "script": { "exec": [
            "var json = pm.response.json();",
            "if (Array.isArray(json) && json[0]) { pm.collectionVariables.set('pontoId', json[0].id); }"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/pontos", "host": ["{{baseUrl}}"], "path": ["pontos"] }
          }
        },
        {
          "name": "Criar ponto",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nome\": \"Novo Ponto\",\n  \"descricao\": \"Descrição do ponto\",\n  \"endereco\": \"Rua Exemplo, 123\"\n}" },
            "url": { "raw": "{{baseUrl}}/pontos", "host": ["{{baseUrl}}"], "path": ["pontos"] }
          }
        },
        {
          "name": "Buscar ponto",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/pontos/{{pontoId}}", "host": ["{{baseUrl}}"], "path": ["pontos","{{pontoId}}"] }
          }
        },
        {
          "name": "Atualizar ponto",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"nome\": \"Nome Atualizado\",\n  \"descricao\": \"Nova descrição\"\n}" },
            "url": { "raw": "{{baseUrl}}/pontos/{{pontoId}}", "host": ["{{baseUrl}}"], "path": ["pontos","{{pontoId}}"] }
          }
        },
        {
          "name": "Desativar ponto",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/pontos/{{pontoId}}", "host": ["{{baseUrl}}"], "path": ["pontos","{{pontoId}}"] }
          }
        },
        {
          "name": "Regenerar agentKey do ponto",
          "event": [{ "listen": "test", "script": { "exec": [
            "var json = pm.response.json();",
            "if (json.agentKey) { pm.collectionVariables.set('agentKeyPonto', json.agentKey); }"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/pontos/{{pontoId}}/agentkey/regenerar", "host": ["{{baseUrl}}"], "path": ["pontos","{{pontoId}}","agentkey","regenerar"] }
          }
        },
        {
          "name": "Listar agendas do ponto",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/pontos/{{pontoId}}/agendas", "host": ["{{baseUrl}}"], "path": ["pontos","{{pontoId}}","agendas"] }
          }
        },
        {
          "name": "Criar agenda",
          "event": [{ "listen": "test", "script": { "exec": [
            "var json = pm.response.json();",
            "if (json.id) { pm.collectionVariables.set('agendaId', json.id); }"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"diasSemana\": [1, 2, 3, 4, 5],\n  \"horaInicio\": \"08:00\",\n  \"horaFim\": \"18:00\"\n}" },
            "url": { "raw": "{{baseUrl}}/pontos/{{pontoId}}/agendas", "host": ["{{baseUrl}}"], "path": ["pontos","{{pontoId}}","agendas"] }
          }
        },
        {
          "name": "Atualizar agenda",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"diasSemana\": [1, 2, 3, 4, 5],\n  \"horaInicio\": \"07:00\",\n  \"horaFim\": \"19:00\",\n  \"ativo\": true\n}" },
            "url": { "raw": "{{baseUrl}}/pontos/{{pontoId}}/agendas/{{agendaId}}", "host": ["{{baseUrl}}"], "path": ["pontos","{{pontoId}}","agendas","{{agendaId}}"] }
          }
        },
        {
          "name": "Excluir agenda",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/pontos/{{pontoId}}/agendas/{{agendaId}}", "host": ["{{baseUrl}}"], "path": ["pontos","{{pontoId}}","agendas","{{agendaId}}"] }
          }
        }
      ]
    },

