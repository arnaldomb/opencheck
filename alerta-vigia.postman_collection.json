    {
      "name": "📱 Field API  (x-agent-key)",
      "description": "Endpoints usados pelo app/dispositivo de campo.\n\nAutenticação: header x-agent-key (não JWT).\n- Sempre use {{agentKeyPonto}} no header x-agent-key\n- Sempre inclua vigilanteId no body para identificar o vigilante\n\nFluxo recomendado:\n1. Execute 'Config completa' para popular agentKeyPonto e vigilanteId automaticamente\n2. Use esses valores em todas as requisições subsequentes",
      "item": [
        {
          "name": "Config completa (inicialização)",
          "event": [{ "listen": "test", "script": { "exec": [
            "var json = pm.response.json();",
            "if (json.agentKeyPonto) { pm.collectionVariables.set('agentKeyPonto', json.agentKeyPonto); }",
            "if (json.vigilanteId)   { pm.collectionVariables.set('vigilanteId',   json.vigilanteId); }",
            "pm.test('Config OK', () => pm.response.to.have.status(200));"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "GET",
            "header": [{ "key": "x-agent-key", "value": "{{agentKeyPonto}}" }],
            "url": { "raw": "{{baseUrl}}/api/field/v1/config", "host": ["{{baseUrl}}"], "path": ["api","field","v1","config"] }
          }
        },
        {
          "name": "Config ciclo (polling leve)",
          "event": [{ "listen": "test", "script": { "exec": [
            "var json = pm.response.json();",
            "if (json.vigilanteId) { pm.collectionVariables.set('vigilanteId', json.vigilanteId); }"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "GET",
            "header": [{ "key": "x-agent-key", "value": "{{agentKeyPonto}}" }],
            "url": { "raw": "{{baseUrl}}/api/field/v1/config/ciclo", "host": ["{{baseUrl}}"], "path": ["api","field","v1","config","ciclo"] }
          }
        },
        {
          "name": "Status do ciclo atual",
          "request": {
            "method": "GET",
            "header": [{ "key": "x-agent-key", "value": "{{agentKeyPonto}}" }],
            "url": { "raw": "{{baseUrl}}/api/field/v1/status", "host": ["{{baseUrl}}"], "path": ["api","field","v1","status"] }
          }
        },
        {
          "name": "Check-in",
          "request": {
            "method": "POST",
            "header": [{ "key": "x-agent-key", "value": "{{agentKeyPonto}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"vigilanteId\": \"{{vigilanteId}}\",\n  \"observacao\": \"Ronda concluída sem ocorrências\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/field/v1/checkin", "host": ["{{baseUrl}}"], "path": ["api","field","v1","checkin"] }
          }
        },
        {
          "name": "Pânico",
          "request": {
            "method": "POST",
            "header": [{ "key": "x-agent-key", "value": "{{agentKeyPonto}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"tipo\": \"PANICO\",\n  \"vigilanteId\": \"{{vigilanteId}}\",\n  \"observacao\": \"Invasão detectada\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/field/v1/panico", "host": ["{{baseUrl}}"], "path": ["api","field","v1","panico"] }
          }
        },
