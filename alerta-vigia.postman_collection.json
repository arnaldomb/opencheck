            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/vigilantes/{{vigilanteId}}/agentkey/regenerar", "host": ["{{baseUrl}}"], "path": ["vigilantes","{{vigilanteId}}","agentkey","regenerar"] }
          }
        }
      ]
    },

    {
      "name": "🔄 Ciclos",
