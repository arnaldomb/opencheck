    {
      "name": "📣 Eventos",
      "item": [
        {
          "name": "Listar eventos",
          "event": [{ "listen": "test", "script": { "exec": [
            "var json = pm.response.json();",
            "if (Array.isArray(json) && json[0]) { pm.collectionVariables.set('eventoId', json[0].id); }"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/eventos?page=1&limit=50",
              "host": ["{{baseUrl}}"], "path": ["eventos"],
              "query": [
                { "key": "page",         "value": "1" },
                { "key": "limit",        "value": "50" },
                { "key": "tipo",         "value": "",           "disabled": true, "description": "CHECKIN | FALHA | PANICO | PANICO_SILENCIOSO | COACAO" },
                { "key": "pontoId",      "value": "",           "disabled": true },
                { "key": "vigilanteId",  "value": "{{vigilanteId}}", "disabled": true },
                { "key": "dataInicio",   "value": "2026-04-01T00:00:00", "disabled": true },
                { "key": "dataFim",      "value": "2026-04-30T23:59:59", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Stats de eventos",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/eventos/stats", "host": ["{{baseUrl}}"], "path": ["eventos","stats"] }
          }
        },
        {
          "name": "Gravação do evento (±5 min)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/eventos/{{eventoId}}/playback", "host": ["{{baseUrl}}"], "path": ["eventos","{{eventoId}}","playback"] }
          }
        },
        {
          "name": "Toggle monitoramento",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/eventos/{{eventoId}}/monitorar", "host": ["{{baseUrl}}"], "path": ["eventos","{{eventoId}}","monitorar"] }
          }
        }
      ]
    },

