                "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
                "url": { "raw": "{{baseUrl}}/config/notificacoes/whatsapp/grupos", "host": ["{{baseUrl}}"], "path": ["config","notificacoes","whatsapp","grupos"] }
