generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────
// SUPERADMIN
// ─────────────────────────────────────

model Superadmin {
  id        String   @id @default(cuid())
  email     String   @unique
  senha     String
  nome      String
  criadoEm DateTime @default(now())
}

// ─────────────────────────────────────
// PLANOS
// ─────────────────────────────────────

// Faixa de preço por quantidade de contas contratadas (Single, Starter,
// Profissional, Enterprise, Sob Cotação). O valor mensal da assinatura é
// calculado como quantidade contratada × precoConta da faixa correspondente.
// precoConta nulo = faixa "Sob Cotação", exige valor manual no superadmin.
model Plano {
  id          String   @id @default(cuid())
  nome        String
  descricao   String?
  faixaMin    Int      @default(1)
  faixaMax    Int?
  precoConta  Decimal? @db.Decimal(10, 2)
  ordem       Int      @default(0)
  ativo       Boolean  @default(true)
  criadoEm    DateTime @default(now())

  assinaturas Assinatura[]
}

// ─────────────────────────────────────
// TENANTS (EMPRESAS CLIENTES)
// ─────────────────────────────────────

model Tenant {
  id           String   @id @default(cuid())
  nome         String
  cnpj         String?  @unique
  email        String   @unique
  telefone     String?
  ativo               Boolean  @default(true)
  onboardingOk        Boolean  @default(false)
  // Logo do cliente (data URI base64) — exibida no painel e nos relatórios
  logoUrl             String?
  criadoEm   DateTime @default(now())

  usuarios              Usuario[]
  pontos                Ponto[]
  operadores            Operador[]
  supervisores          Supervisor[]
  assinatura            Assinatura?
  eventos               Evento[]
  ciclos                ConfigCiclo[]
  notifConfigs          ConfigNotificacao[]
  onboarding            OnboardingStep?
  configsAbertura       ConfigAbertura[]
  registrosAbertura     RegistroAbertura[]
  registrosSupervisor   RegistroSupervisor[]
}

model Usuario {
  id         String   @id @default(cuid())
  tenantId   String
  email      String   @unique
  nome       String
  papel      Papel    @default(OPERADOR)
  senha      String
  ativo      Boolean  @default(true)
  criadoEm DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────
// ASSINATURA ASAAS
// ─────────────────────────────────────

model Assinatura {
  id             String           @id @default(cuid())
  tenantId       String           @unique
  planoId        String
  periodicidade  Periodicidade    @default(MENSAL)
  status         AssinaturaStatus @default(TRIAL)

  asaasCustomerId     String? @unique
  asaasSubscriptionId String? @unique
  externalReference   String  @unique @default(cuid())

  pontosContratados   Int
  proximaCobrancaEm   DateTime?
  trialAteEm          DateTime?
  canceladaEm         DateTime?

  // Dados de faturamento — cadastrados apenas pelo superadmin
  razaoSocialFaturamento String?
  cnpjFaturamento        String?
  emailFaturamento       String?
  diaVencimento          Int?

  criadoEm           DateTime    @default(now())
  atualizadoEm       DateTime    @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  plano     Plano      @relation(fields: [planoId], references: [id])
  cobrancas Cobranca[]
}

model Cobranca {
  id             String        @id @default(cuid())
  assinaturaId   String
  asaasPaymentId String        @unique
  asaasEventId   String?       @unique
  valor          Decimal       @db.Decimal(10, 2)
  status         CobrancaStatus
  billingType    String
  vencimentoEm   DateTime
  paguEm         DateTime?
  criadoEm      DateTime      @default(now())

  assinatura Assinatura @relation(fields: [assinaturaId], references: [id])
}

// ─────────────────────────────────────
// PONTOS (PORTARIAS)
// ─────────────────────────────────────

model Ponto {
  id         String   @id @default(cuid())
  tenantId   String
  nome       String
  descricao  String?
  endereco   String?
  latitude   Float?
  longitude  Float?
  ativo      Boolean  @default(true)
  criadoEm DateTime @default(now())

  canalAlerta CanalAlerta?

  ctrlsafeAccount    String?
  ctrlsafePartition  String?
  ctrlsafeZone       String?
  ctrlsafeReceiver   String?
  ctrlsafeLine       String?
  ctrlsafeLicenseKey String?
  ctrlsafeAgentToken String?
  ctrlsafeInstallId  String?

  agentKey   String?  @unique
  agentKeyAt DateTime?

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  operadores          Operador[]           @relation("OperadorPontos")
  supervisores        Supervisor[]         @relation("SupervisorPontos")
  eventos             Evento[]
  configCiclo         ConfigCiclo?
  execucoes           ExecucaoCiclo[]
  configAbertura      ConfigAbertura?
  registrosAbertura   RegistroAbertura[]
  registrosSupervisor RegistroSupervisor[]
}

// ─────────────────────────────────────
// OPERADORES
// ─────────────────────────────────────

model Operador {
  id         String   @id @default(cuid())
  tenantId   String
  nome       String
  telefone   String?
  rfid       String?
  codigo     String?
  ativo      Boolean  @default(true)
  criadoEm DateTime @default(now())

  agentKey   String?  @unique
  agentKeyAt DateTime?

  tenant              Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pontos              Ponto[]            @relation("OperadorPontos")
  registrosAbertura   RegistroAbertura[] @relation("OperadorAbertura")
  registrosFechamento RegistroAbertura[] @relation("OperadorFechamento")

  @@unique([tenantId, codigo])
}

// ─────────────────────────────────────
// SUPERVISORES
// ─────────────────────────────────────

model Supervisor {
  id         String    @id @default(cuid())
  tenantId   String
  nome       String
  telefone   String?
  codigo     String?
  ativo      Boolean   @default(true)
  criadoEm  DateTime  @default(now())

  agentKey   String?   @unique
  agentKeyAt DateTime?

  tenant               Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pontos               Ponto[]              @relation("SupervisorPontos")
  registros            RegistroSupervisor[]
  registrosAbertura    RegistroAbertura[]   @relation("SupervisorAbertura")
  registrosFechamento  RegistroAbertura[]   @relation("SupervisorFechamento")

  @@unique([tenantId, codigo])
}

model RegistroSupervisor {
  id           String                 @id @default(cuid())
  supervisorId String
  pontoId      String
  tenantId     String
  tipo         TipoRegistroSupervisor
  registradoEm DateTime              @default(now())
  ip           String?
  userAgent    String?

  supervisor Supervisor @relation(fields: [supervisorId], references: [id])
  ponto      Ponto      @relation(fields: [pontoId], references: [id])
  tenant     Tenant     @relation(fields: [tenantId], references: [id])
}

// ─────────────────────────────────────
// MÓDULO DE ABERTURA DE LOJAS
// ─────────────────────────────────────

model ConfigAbertura {
  id           String   @id @default(cuid())
  tenantId     String
  pontoId      String   @unique
  emailAlerta  String?
  ativo        Boolean  @default(true)
  // Códigos de evento para CTRL+SAFE / monitoramento
  codigoCheckInPrazo     String  @default("1400") // ABERTURA_CHECKIN NO_PRAZO
  codigoCheckInAtrasado  String  @default("1401") // ABERTURA_CHECKIN ATRASADO
  codigoAusente          String  @default("1402") // ABERTURA_AUSENTE
  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  tenant    Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ponto     Ponto              @relation(fields: [pontoId], references: [id], onDelete: Cascade)
  turnos    TurnoAbertura[]
  registros RegistroAbertura[]
}

model TurnoAbertura {
  id                           String   @id @default(cuid())
  configId                     String
  diasSemana                   Int[]    // 0=Dom 1=Seg … 6=Sáb; vazio = todos os dias
  horaAbertura                 String   // "08:00"
  toleranciaMinutos            Int      @default(30)
  horaFechamento               String?  // "18:00" — null = sem controle de fechamento
  toleranciaFechamentoMinutos  Int      @default(15)
  checkinFechamentoObrigatorio Boolean  @default(false) // false = auto-fecha; true = exige check-in
  ativo                        Boolean  @default(true)
  criadoEm                    DateTime @default(now())

  config    ConfigAbertura     @relation(fields: [configId], references: [id], onDelete: Cascade)
  registros RegistroAbertura[]
}

model RegistroAbertura {
  id             String         @id @default(cuid())
  tenantId       String
  pontoId        String
  configId       String
  turnoId        String?
  data           DateTime       @db.Date
  status         StatusAbertura @default(AUSENTE)
  deadlineEm     DateTime
  abertaEm       DateTime?
  operadorId     String?
  supervisorId   String?
  nomeComputador String?
  usuarioWindows String?
  jobId          String?

  // Controle de fechamento
  statusFechamento            StatusFechamento?
  fechamentoEm                DateTime?
  fechamentoOperadorId        String?
  fechamentoSupervisorId      String?
  fechamentoJobId             String?

  criadoEm       DateTime       @default(now())
  atualizadoEm   DateTime       @updatedAt

  tenant                Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ponto                 Ponto           @relation(fields: [pontoId], references: [id])
  config                ConfigAbertura  @relation(fields: [configId], references: [id])
  turno                 TurnoAbertura?  @relation(fields: [turnoId], references: [id])
  operador              Operador?       @relation("OperadorAbertura",    fields: [operadorId],              references: [id])
  fechamentoOperador    Operador?       @relation("OperadorFechamento",  fields: [fechamentoOperadorId],    references: [id])
  supervisor            Supervisor?     @relation("SupervisorAbertura",  fields: [supervisorId],            references: [id])
  fechamentoSupervisor  Supervisor?     @relation("SupervisorFechamento",fields: [fechamentoSupervisorId],  references: [id])

  @@unique([pontoId, data])
}

// ─────────────────────────────────────
// CÂMERAS EZVIZ
// ─────────────────────────────────────

// ─────────────────────────────────────
// CICLOS DE ALERTA
// ─────────────────────────────────────

model ConfigCiclo {
  id                String   @id @default(cuid())
  tenantId          String
  pontoId           String?  @unique
  nome              String   @default("Padrão")

  duracaoMinutos    Int      @default(10)
  toleranciaMinutos Int      @default(2)
  avisoAntesMin     Int      @default(5)

  codigoCheckin     String   @default("1602")
  codigoPanico      String   @default("1122")
  codigoFalha       String   @default("1130")

  enviarAvisoWpp    Boolean  @default(true)
  autoReiniciar     Boolean  @default(true)
  ativo             Boolean  @default(true)

  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt

  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ponto     Ponto?        @relation(fields: [pontoId], references: [id])
  execucoes ExecucaoCiclo[]
  agendas   AgendaCiclo[]
}

model ExecucaoCiclo {
  id           String      @id @default(cuid())
  configId     String
  pontoId      String
  iniciadoEm   DateTime    @default(now())
  expiraEm     DateTime
  finalizadoEm DateTime?
  status       CicloStatus @default(EM_ANDAMENTO)
  checkinEm    DateTime?
  alertaEm     DateTime?

  avisoJobId  String?
  expiraJobId String?

  config ConfigCiclo @relation(fields: [configId], references: [id])
  ponto  Ponto       @relation(fields: [pontoId], references: [id])
}

// ─────────────────────────────────────
// AGENDAS (horários de operação por turno)
// ─────────────────────────────────────

model AgendaCiclo {
  id         String   @id @default(cuid())
  configId   String
  // 0=Dom, 1=Seg, 2=Ter, 3=Qua, 4=Qui, 5=Sex, 6=Sab
  diasSemana Int[]
  horaInicio String   // "08:00"
  horaFim    String   // "18:00"
  ativo      Boolean  @default(true)
  criadoEm  DateTime @default(now())

  config ConfigCiclo @relation(fields: [configId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────
// AGENT KEY LOG (auditoria de acesso de campo)
// ─────────────────────────────────────

model AgentKeyLog {
  id           String       @id @default(cuid())
  tipo         AgentKeyTipo
  referenciaId String
  tenantId     String
  acao         String
  ip           String?
  userAgent    String?
  criadoEm    DateTime     @default(now())
}

// ─────────────────────────────────────
// EVENTOS
// ─────────────────────────────────────

model Evento {
  id          String      @id @default(cuid())
  tenantId    String
  pontoId     String?
  tipo        TipoEvento
  canal       CanalAlerta?
  encaminhado Boolean     @default(false)
  monitorado  Boolean     @default(false)
  ocorridoEm  DateTime    @default(now())
  criadoEm   DateTime    @default(now())
  meta        Json?

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ponto  Ponto?  @relation(fields: [pontoId], references: [id])
}

// ─────────────────────────────────────
// CONFIGURAÇÃO GLOBAL DE EVENTOS (SUPERADMIN)
// ─────────────────────────────────────

model ConfigEventoGlobal {
  id      String @id @default("global")
  // JSON: Record<TipoEvento, string> — código CTRL+SAFE por tipo de evento
  codigos Json   @default("{\"CHECKIN\":\"1602\",\"PANICO\":\"1120\",\"PANICO_SILENCIOSO\":\"1122\",\"COACAO\":\"1121\",\"FALHA\":\"1130\",\"AVISO\":\"1140\",\"RESTAURACAO\":\"1150\",\"TESTE\":\"1602\",\"ABERTURA_CHECKIN\":\"1400\",\"ABERTURA_AUSENTE\":\"1402\",\"FECHAMENTO_CHECKIN\":\"1410\",\"FECHAMENTO_AUSENTE\":\"1412\"}")
  // JSON: Record<TipoEvento, string> — tipo de evento CTRL+SAFE (alert | restore | test)
  tiposCtrlSafe Json @default("{\"PANICO\":\"alert\",\"PANICO_SILENCIOSO\":\"alert\",\"COACAO\":\"alert\",\"FALHA\":\"alert\",\"AVISO\":\"alert\",\"RESTAURACAO\":\"restore\",\"TESTE\":\"test\",\"ABERTURA_AUSENTE\":\"alert\",\"FECHAMENTO_AUSENTE\":\"alert\"}")
  atualizadoEm DateTime @updatedAt
}

// ─────────────────────────────────────
// NOTIFICAÇÕES
// ─────────────────────────────────────

model ConfigNotificacao {
  id       String          @id @default(cuid())
  tenantId String
  tipo     TipoNotificacao
  ativo    Boolean         @default(true)

  whatsappDestino        String?
  whatsappEventos        String[] // TipoEvento[] que disparam WhatsApp; vazio = todos
  whatsappGrupoJid       String?  // ID do grupo WhatsApp (Z-API: "1203...-group") para envio de alertas
  whatsappGrupoNome      String?  // Nome do grupo (cache para exibição)
  whatsappInstStatus     String?  @default("DESCONECTADO") // DESCONECTADO | AGUARDANDO_QR | CONECTADO
  // Z-API — credenciais da instância do cliente
  zapiInstanceId         String?
  zapiToken              String?
  zapiClientToken        String?

  ctrlsafeLicenseKey String?
  ctrlsafeAgentToken String?
  ctrlsafeInstallId  String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, tipo])
}

// ─────────────────────────────────────
// ONBOARDING
// ─────────────────────────────────────

model OnboardingStep {
  id          String    @id @default(cuid())
  tenantId    String    @unique
  ponto       Boolean   @default(false)
  operador   Boolean   @default(false)
  ciclo       Boolean   @default(false)
  notificacao Boolean   @default(false)
  teste       Boolean   @default(false)
  concluidoEm DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────
// ENUMS
// ─────────────────────────────────────

enum Papel {
  SUPERADMIN
  ADMIN
  OPERADOR
}

enum Periodicidade {
  MENSAL
  ANUAL
}

enum AssinaturaStatus {
  TRIAL
  ATIVA
  INADIMPLENTE
  SUSPENSA
  CANCELADA
}

enum CobrancaStatus {
  PENDENTE
  CONFIRMADA
  RECEBIDA
  VENCIDA
  CANCELADA
  ESTORNADA
}

enum CicloStatus {
  EM_ANDAMENTO
  CONCLUIDO
  ALERTA
  FALHA
  CANCELADO
}

enum CanalAlerta {
  WHATSAPP
  CTRLSAFE
}

enum TipoNotificacao {
  WHATSAPP
  CTRLSAFE
}

enum TipoEvento {
  CHECKIN
  ABERTURA_CHECKIN
  ABERTURA_AUSENTE
  FECHAMENTO_CHECKIN
  FECHAMENTO_AUSENTE
  SUPERVISOR_ENTRADA
  SUPERVISOR_SAIDA
  PANICO
  PANICO_SILENCIOSO
  COACAO
  FALHA
  AVISO
  RESTAURACAO
  TESTE
}

enum TipoRegistroSupervisor {
  ENTRADA
  SAIDA
}

enum StatusFechamento {
  NO_PRAZO
  ATRASADO
  AUSENTE
  AUTO_FECHADO
}

enum AgentKeyTipo {
  PONTO
  OPERADOR
  SUPERVISOR
}

enum StatusAbertura {
  NO_PRAZO
  ATRASADO
  AUSENTE
}
