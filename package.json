{
  "name": "alerta-vigia",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @alerta-vigia/database prisma generate",
    "db:migrate": "pnpm --filter @alerta-vigia/database prisma migrate dev",
    "db:push": "pnpm --filter @alerta-vigia/database prisma db push",
    "db:seed": "pnpm --filter @alerta-vigia/database prisma db seed",
    "db:studio": "pnpm --filter @alerta-vigia/database prisma studio"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0",
    "prettier": "^3.3.0",
    "eslint": "^9.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.14.0"
}
