<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>OpenCheck</AssemblyName>
    <RootNamespace>OpenCheck.Kiosk</RootNamespace>
    <Product>OpenCheck</Product>
    <AssemblyTitle>OpenCheck</AssemblyTitle>
    <ApplicationHighDpiMode>PerMonitorV2</ApplicationHighDpiMode>
    <ApplicationIcon>..\..\installer\app.ico</ApplicationIcon>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\OpenCheck.Common\OpenCheck.Common.csproj" />
  </ItemGroup>
</Project>
